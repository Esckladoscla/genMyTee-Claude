# Copy this file to .env and fill in your own values

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_KEY=

# ── Printful ─────────────────────────────────────────────────────────────────
PRINTFUL_API_KEY=
PRINTFUL_CONFIRM=false        # true = auto-confirma pedidos. Déjalo en false durante pruebas.
PRINTFUL_PLACEMENT=front
PRINTFUL_STITCH_COLOR=black

# ── Cloudflare R2 (almacenamiento imágenes) ───────────────────────────────────
R2_PUBLIC_BASE_URL=https://assets.genmytee.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=genmytee-printful

# ── Stripe (pagos) ────────────────────────────────────────────────────────────
# Claves en modo TEST durante desarrollo (empiezan por sk_test_ y pk_test_)
# Claves en modo LIVE en producción (empiezan por sk_live_ y pk_live_)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=        # Obtenido al registrar el webhook en el dashboard de Stripe

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGINS=https://genmytee.com

# ── IA ────────────────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_IMAGE_SIZE=auto
