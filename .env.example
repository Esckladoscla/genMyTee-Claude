# Copy this file to .env and fill in your own values
# OpenAI API key for image generation
OPENAI_KEY=
# Printful API key for order creation
PRINTFUL_API_KEY=

# Default Printful variant ID for the product to print on (e.g., Bella+Canvas 3001 in white)
PRINTFUL_VARIANT_ID_DEEFAULT=9329
#PRINTFUL_VARIANT_ID_DEFAULT=13363


# Port for the Express server
PORT=3000

R2_PUBLIC_BASE_URL=https://assets.genmytee.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=genmytee-printful

# Si no pones PRINTFUL_CONFIRM=false, Printful intentará confirmar el pedido. Mejor déjalo en borrador durante las pruebas.
PRINTFUL_CONFIRM=false
# PRINTFUL_CONFIRM=true
PRINTFUL_PLACEMENT=front
AI_IMAGE_SIZE=auto

# Shopify Admin API (NO Storefront)
SHOPIFY_STORE=
SHOPIFY_ACCESS_TOKEN=   # el token Admin API de tu app privada

# Color hilo bordado
PRINTFUL_STITCH_COLOR=black

# AI_ENABLED=false hace que ni intente llamar a OpenAI mientras estás capado
# PRINTFUL_CONFIRM=false deja pedidos en draft.
# AI_IMAGE_SIZE=auto evita tamaños inválidos

AI_ENABLED=true



SHOPIFY_WEBHOOK_SECRET=
